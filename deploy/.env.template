# DojoZero Docker Environment Variables
# Copy this file to ../.env and fill in the values
#
# IMPORTANT: Never commit .env files with real credentials to git

# =============================================================================
# Required: LLM API Keys
# =============================================================================

# DashScope API key for Qwen LLM calls (agent reasoning)
DOJOZERO_DASHSCOPE_API_KEY=

# Tavily API key for web search (pre-game data fetching)
DOJOZERO_TAVILY_API_KEY=

# =============================================================================
# Required: Alibaba Cloud Credentials
# =============================================================================

# Used by both SLS (traces) and OSS (backup)
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=

# =============================================================================
# Required: SLS Configuration (Trace Storage)
# =============================================================================

# SLS endpoint (region-specific)
# Examples: cn-hangzhou.log.aliyuncs.com, cn-wulanchabu.log.aliyuncs.com
DOJOZERO_SLS_ENDPOINT=cn-wulanchabu.log.aliyuncs.com

# SLS project name
DOJOZERO_SLS_PROJECT=

# SLS logstore for trace data
DOJOZERO_SLS_LOGSTORE=dojozero-traces

# =============================================================================
# Required: OSS Configuration (Trial Data Backup)
# =============================================================================

# OSS endpoint (region-specific, should match SLS region for efficiency)
# Examples: oss-cn-hangzhou.aliyuncs.com, oss-cn-wulanchabu.aliyuncs.com
DOJOZERO_OSS_ENDPOINT=oss-cn-wulanchabu.aliyuncs.com

# OSS bucket name
DOJOZERO_OSS_BUCKET=

# Optional: prefix for all keys (e.g., "prod/" or "staging/")
DOJOZERO_OSS_PREFIX=

# =============================================================================
# Optional: Polymarket Integration
# =============================================================================

# Private key for Polymarket CLOB authentication (if using real betting)
# DOJOZERO_POLY_PRIVATE_KEY=0x...

# =============================================================================
# Optional: Proxy Configuration
# =============================================================================

# HTTP proxy URL for external API requests
# DOJOZERO_PROXY_URL=http://proxy.example.com:8080

# =============================================================================
# Optional: Timezone
# =============================================================================

# Container timezone (affects scheduling logs, default: UTC)
# TZ=America/New_York
